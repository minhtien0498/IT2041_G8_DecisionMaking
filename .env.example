GEOAPIFY_API_KEY=your_geoapify_api_key_here

# Solution 1 — Sequential 2-LLM Pipeline
# Danh sách key rotation (phân tách dấu phẩy) — thử theo thứ tự khi key trước bị
# rate-limit/hết quota/lỗi auth. Có thể để 1 key duy nhất (không cần dấu phẩy).
OPENROUTER_API_KEYS=your_openrouter_api_key_here
MAPBOX_TOKEN=your_mapbox_public_token_here

# Nguồn enrichment dùng chung cho DB loader + tool fetch_nearby_custom/get_distance_to_place
# (mapbox | geoapify | overpass, mặc định mapbox nếu để trống). Đổi giá trị này là đổi
# hẳn cả dataset nạp vào Postgres lẫn API thật mà tool gọi — không cần sửa code.
SOLUTION1_ENRICHMENT_PROVIDER=mapbox

# Postgres (local dev, docker-compose)
SOLUTION1_DB_DSN=postgresql://solution1:solution1@localhost:5433/solution1

# LLM model config
SOLUTION1_LLM_MODEL_REASONING=nvidia/nemotron-3-ultra-550b-a55b:free
SOLUTION1_LLM_MODEL_EXPLANATION=openai/gpt-oss-120b:free
SOLUTION1_LLM_MODEL_POOL=nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,qwen/qwen3-coder:free,openai/gpt-oss-20b:free

